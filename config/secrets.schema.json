{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secrets Configuration",
  "type": "object",
  "properties": {
    "backend": {
      "type": "string",
      "enum": ["env", "vault", "aws_secrets_manager", "azure_key_vault"]
    },
    "prefix": { "type": ["string", "null"] },
    "vault_addr": { "type": ["string", "null"], "format": "uri" },
    "vault_token_env": { "type": ["string", "null"] },
    "vault_mount": { "type": ["string", "null"] },
    "aws_region": { "type": ["string", "null"] },
    "aws_profile": { "type": ["string", "null"] },
    "azure_vault_name": { "type": ["string", "null"] }
  },
  "required": ["backend"],
  "additionalProperties": false,
  "allOf": [
    {
      "if": { "properties": { "backend": { "const": "vault" } } },
      "then": { "required": ["vault_addr"], "properties": {"vault_addr": {"type": "string"}} }
    },
    {
      "if": { "properties": { "backend": { "const": "aws_secrets_manager" } } },
      "then": { "required": ["aws_region"] }
    },
    {
      "if": { "properties": { "backend": { "const": "azure_key_vault" } } },
      "then": { "required": ["azure_vault_name"] }
    }
  ]
}
